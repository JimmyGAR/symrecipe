{% extends 'base.html.twig' %}

{% block title %}SymRecipe - Mes recettes{% endblock %}

{% block body %}
<div class="container mt-4">
    {% for message in app.flashes('success') %}
    <div class="alert alert-dismissible alert-success mt-4">
        {{ message }}
    </div>
    {% endfor %}
    <h1>Mes recettes</h1>

    {% if not recipes.items is same as ([]) %}
    <h4>{{ recipes.getTotalItemCount }} recipes</h4>
    <table class="table table-hover">
        <thread>
            <tr class="table-secondary">
                <th scope="col">Numéro</th>
                <th scope="col">Name</th>
                {# <th scope="col">Time</th> #}
                {# <th scope="col">NbPersons</th> #}
                <th scope="col">Difficulty</th>
                {# <th scope="col">Description</th> #}
                <th scope="col">Price</th>
                {# <th scope="col">Favoris</th> #}
                <th scope="col">CreatedAt</th>
                <th scope="col">Édition</th>
                <th scope="col">Suppression</th>
            </tr>
        </thread>
        <tbody>
            {% for recipe in recipes %}
            <tr class="table-dark">
                <th scope="row">{{ recipe.id }}</th>
                <td>{{ recipe.name }}</td>
                {# <td>{{ recipe.time ?? '?'}}</td> #}
                {# <td>{{ recipe.nbPersons ?? 'Non renseigné' }}</td> #}
                <td>{{ recipe.difficulty ?? 'Non renseigné' }}</td>
                {# <td>{{ recipe.description }}</td> #}
                <td>{{ recipe.price ?? '?'}}</td>
                {# <td>{{ recipe.isFavorite ? "Oui" : 'Non'}}</td> #}
                <td>{{ recipe.createdAt|date('d/m/y') }}</td>
                <td>
                    <a href="{{ path('recipe_edit', { id: recipe.id}) }}" class="btn btn-info">Modifier</a>
                </td>
                <td>
                    <a href="{{ path('recipe_remove', { id: recipe.id}) }}" class="btn btn-warning">Supprimer</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    <div class="d-flex justify-content-center nt-4">
        {{ knp_pagination_render(recipes) }}
    </div>
    {% else %}
    <h4>Il n'y a aucune recette !</h4>
    {% endif %}
</div>
{% endblock %}